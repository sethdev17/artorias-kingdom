<!DOCTYPE html>
<html lang="ro">
<head>
  <title>Artoria's Kingdom România — Contact</title>
  <%- include('partials/head') %>
  <!-- Stilul specific doar pentru formular -->
  <link rel="stylesheet" href="/contact-page/contact.css">
  <script src="/logic.js" defer></script>
  <script src="/contact-page/contact.js" defer></script>
</head>

<body class="loading kingdom">
    <%- include('partials/header') %>

    <main class="contact-main">
        <section class="contact-form-section">
            <div class="contact-intro">
                <h1>Completează formularul de mai jos și trimite-ne un mesaj.</h1>
                <p>Introduce-ți datele aferente mai jos și contactează-ne dacă ai vreo curiozitate, o problemă, dorești să afli mai multe despre noi sau vrei doar să ne trimiți un mesaj.</p>
            </div>

            <form id="contact-form" novalidate>
                <div class="field-group">
                    <div class="input-wrap">
                        <input type="text" id="nume" name="nume" placeholder="" autocomplete="name">
                        <label for="nume">Nume</label>
                    </div>

                    <div class="input-wrap required">
                        <input type="text" id="prenume" name="prenume" placeholder="" required autocomplete="given-name">
                        <label for="prenume">Prenume</label>
                    </div>

                    <div class="input-wrap required">
                        <input type="email" id="email" name="email" placeholder="" required autocomplete="email">
                        <label for="email">Email-ul tău</label>
                    </div>

                    <div class="textarea-wrap required">
                        <label for="mesaj" class="textarea-label">Mesajul tău</label>
                        <textarea id="mesaj" name="mesaj" rows="8" placeholder="" required></textarea>
                        <div id="word-count" class="word-count">500</div>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="button" id="reset-btn" class="btn btn-grey">Refă</button>
                    <button type="submit" id="submit-btn" class="btn btn-blue">Trimite!</button>
                </div>
                <div id="form-message" class="form-message"></div>
            </form>
        </section>
    </main>

    <%- include('partials/footer') %>

    <script>
      window.addEventListener('load', () => {
        document.body.classList.remove('loading');
      });
    </script>
</body>
</html>